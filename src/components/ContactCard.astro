---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  name: string;
  email: string;
  image: ImageMetadata;
}

const { name, email, image } = Astro.props;
---

<div
  class="flex items-center gap-6 bg-[var(--sl-color-gray-6)] p-6 rounded-xl"
>
  <div class="flex-1">
    <p class="text-xl font-semibold mb-2">{name}</p>
    <p class="mt-2">
      <a href={`mailto:${email}`}>{email}</a>
    </p>
  </div>
  <Image
    src={image}
    alt={`Foto von ${name}`}
    class="w-[120px] h-[120px] rounded-full object-cover"
    loading="eager"
  />
</div>
